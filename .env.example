# Application
APP_ENVIRONMENT=development
APP_DEBUG=false
APP_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# PostgreSQL / pgvector
POSTGRES_DB=knowledge_agent
POSTGRES_USER=knowledge
POSTGRES_PASSWORD=change-me
APP_DATABASE_URL=postgresql+psycopg://knowledge:change-me@postgres:5432/knowledge_agent

# Redis
APP_REDIS_URL=redis://redis:6379/0

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-too
APP_NEO4J_URI=bolt://neo4j:7687
APP_NEO4J_USER=neo4j
APP_NEO4J_PASSWORD=change-me-too

# Added now so later phases do not require changing the configuration contract.
# It is not used by Phase 0.
APP_OPENAI_API_KEY=

